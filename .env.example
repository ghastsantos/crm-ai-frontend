# Base URL of crm-ai-backend (no trailing slash)
VITE_API_BASE_URL=http://localhost:3000

# Optional dev server port. If busy, npm run dev asks for another one.
# VITE_PORT=5173

# true = sessão via cookie httpOnly no backend (fetch com credentials: include; alinhar CORS no backend)
# false ou omitir = Bearer no sessionStorage (padrão para desenvolvimento simples)
VITE_AUTH_HTTPONLY_COOKIE=false
